# ── Required ──────────────────────────────────────
TELEGRAM_TOKEN=your_telegram_bot_token_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Chat IDs ───────────────────────────────────────
# Run the bot, each person sends /start — it shows their chat ID.
# CHAT_ID_EN → you (English by default, Portuguese on request)
# CHAT_ID_PT → wife (Portuguese by default, English on request)
# Leave CHAT_ID_PT=0 if wife hasn't set up yet — add it later.
CHAT_ID_EN=0
CHAT_ID_PT=0
# Optional legacy: if CHAT_ID_EN is 0, YOUR_CHAT_ID is used as CHAT_ID_EN (old single-user setups).
# YOUR_CHAT_ID=0

# ── Daily tip schedule (24h format, UTC) ──────────
# 11:00 UTC = 8:00 AM Brazil time (BRT = UTC-3)
DAILY_TIP_HOUR=11
DAILY_TIP_MINUTE=0

# ── Optional: Voice messages + TTS pronunciation ──
# Get a key at https://platform.openai.com
# Used for: voice message transcription + /falar pronunciation
# Leave empty to disable — everything else still works.
OPENAI_API_KEY=
