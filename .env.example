# ── Required ───────────────────────────────────────────────────────
TELEGRAM_TOKEN=your_telegram_bot_token_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Daily message schedule (24h UTC) ───────────────────────────────
# 11:00 UTC = 8:00 AM Brazil time (BRT = UTC-3)
# Users are auto-registered when they send /start — no chat IDs needed.
DAILY_TIP_HOUR=11
DAILY_TIP_MINUTE=0

# ── Optional: Voice transcription + /falar pronunciation ───────────
# Get a key at https://platform.openai.com — costs cents/month
# Leave empty to disable voice features.
OPENAI_API_KEY=
