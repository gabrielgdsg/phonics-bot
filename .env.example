# ── Required ──────────────────────────────────────
TELEGRAM_TOKEN=your_telegram_bot_token_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Your Telegram Chat ID ─────────────────────────
# Run the bot once, send /start, it will show your chat ID.
# Then paste it here and restart the bot.
YOUR_CHAT_ID=0

# ── Daily tip schedule (24h format, UTC) ──────────
# 11:00 UTC = 8:00 AM Brazil time (BRT = UTC-3)
DAILY_TIP_HOUR=11
DAILY_TIP_MINUTE=0

# ── Optional: Voice messages via OpenAI Whisper ───
# Get a key at https://platform.openai.com
# Leave empty to disable voice for now.
OPENAI_API_KEY=
